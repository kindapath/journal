# Copy this file to local.properties and fill in your values.
# local.properties is gitignored and will not be committed.

# Android SDK location (set automatically by Android Studio)
# sdk.dir=/path/to/android/sdk

# Supabase
supabase.url=https://your-project.supabase.co
supabase.schema=public
supabase.clientApiKey=your_supabase_anon_key
supabase.anonAuthEnabled=false

# PowerSync
powersync.url=https://your-instance.powersync.journeyapps.com
powersync.devToken=

# Debug mode
debug=true
